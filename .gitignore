intrinsics.json

# CAD 파일: 기본은 ignore (용량/라이선스 이슈), cad_models/ 안의 것만 예외 포함
# (사용자가 직접 모든 CAD 추적 원하면 아래 negation 라인을 더 추가/제거)
*.stl
*.STL
*.obj
*.OBJ
*.step
*.STEP
!cad_models/**/*.stl
!cad_models/**/*.STL
!cad_models/**/*.obj
!cad_models/**/*.OBJ
!cad_models/**/*.step
!cad_models/**/*.STEP

